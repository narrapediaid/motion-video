# Public desktop app environment (safe to share)
# Save this as ".env.public" or ".env.public.txt"
# Recommended location for installed app:
#   %APPDATA%\Motion Video Batch UI\
# Alternative location:
#   same folder as app executable

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY
SAKURUPIAH_IS_PRODUCTION=true

# Required for public mode checkout/webhook processing
SUBSCRIPTION_BACKEND_URL=https://apimotion.narrapedia.top/subscription

# Optional aliases supported by app:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
