# Supabase project
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_ANON_KEY=your_anon_key_jwt_or_publishable_key

# INTERNAL ONLY (jangan dibagikan ke publik)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional frontend aliases
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_jwt_or_publishable_key

# Midtrans
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=true
# INTERNAL ONLY (jangan dibagikan ke publik)
MIDTRANS_SERVER_KEY=your_midtrans_server_key

# Public app checkout backend (wajib untuk build publik)
SUBSCRIPTION_BACKEND_URL=https://apimotion.narrapedia.top/subscription
